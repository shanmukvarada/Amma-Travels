rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Admin Entity Validation ---
    function isValidAdmin(data) {
      return data.keys().hasAll(['email']) &&
             data.email is string && data.email.size() <= 256 &&
             (data.get('role', 'admin') == 'admin');
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && adminId == request.auth.uid && 
                    (request.auth.token.email == "mrlucifer1466@gmail.com" || 
                     request.auth.token.email.matches('.*@ammatravels\\.com')) && 
                    isValidAdmin(incoming());
      allow update, delete: if isAdmin() && adminId != request.auth.uid; // don't delete oneself
    }

    // --- Vehicle Entity Validation ---
    function isValidVehicle(data) {
      return data.keys().hasAll(['type', 'name', 'status', 'createdAt', 'updatedAt']) &&
             data.type in ['car', 'bike'] &&
             data.name is string && data.name.size() <= 100 &&
             data.get('model', '') is string && data.get('model', '').size() <= 100 &&
             data.get('year', '') is string && data.get('year', '').size() <= 20 &&
             data.get('description', '') is string && data.get('description', '').size() <= 5000 &&
             data.get('capacity', 0) is number &&
             data.get('fuelType', 'petrol') in ['petrol', 'diesel', 'cng', 'ev', ''] &&
             data.get('images', []) is list && data.get('images', []).size() <= 10 &&
             data.status in ['available', 'maintenance', 'on-road'] &&
             data.get('pricingTiers', []) is list && data.get('pricingTiers', []).size() <= 20 &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    match /vehicles/{vehicleId} {
      allow read: if true; // Public read for vehicles
      
      allow create: if isAdmin() &&
                    isValidId(vehicleId) &&
                    isValidVehicle(incoming()) &&
                    incoming().createdAt == request.time &&
                    incoming().updatedAt == request.time;
      
      allow update: if isAdmin() &&
                    isValidId(vehicleId) &&
                    isValidVehicle(incoming()) &&
                    incoming().createdAt == existing().createdAt &&
                    incoming().updatedAt == request.time && (
                      incoming().diff(existing()).affectedKeys().hasOnly(['type', 'name', 'model', 'year', 'capacity', 'fuelType', 'images', 'status', 'description', 'pricingTiers', 'updatedAt'])
                    );
      
      allow delete: if isAdmin() && isValidId(vehicleId);
    }

    // --- Booking Entity Validation ---
    function isValidBooking(data) {
      return data.keys().hasAll(['vehicleId', 'customerName', 'customerPhone', 'status', 'userId', 'createdAt', 'updatedAt']) &&
             data.vehicleId is string && data.vehicleId.size() <= 128 &&
             data.customerName is string && data.customerName.size() <= 100 &&
             data.customerPhone is string && data.customerPhone.size() <= 20 &&
             data.get('customerAddress', '') is string && data.get('customerAddress', '').size() <= 500 &&
             data.get('aadhaarDoc', '') is string && data.get('aadhaarDoc', '').size() <= 5000000 &&
             data.get('dlDoc', '') is string && data.get('dlDoc', '').size() <= 5000000 &&
             data.status in ['pending', 'approved', 'completed', 'cancelled'] &&
             data.userId is string && data.userId.size() <= 128 &&
             data.get('selectedTier', {}) is map &&
             data.get('totalAmount', 0) is number &&
             (data.get('startTime', null) == null || data.get('startTime', null) is timestamp) &&
             (data.get('expectedReturnTime', null) == null || data.get('expectedReturnTime', null) is timestamp) &&
             (data.get('actualReturnTime', null) == null || data.get('actualReturnTime', null) is timestamp) &&
             data.get('startKm', 0) is number &&
             data.get('endKm', 0) is number &&
             data.get('extraKm', 0) is number &&
             data.get('extraCharges', 0) is number &&
             data.get('finalAmount', 0) is number &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    match /bookings/{bookingId} {
      allow get: if isValidId(bookingId) && (isAdmin() || (isSignedIn() && existing().userId == request.auth.uid));
      allow list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      
      allow create: if isSignedIn() &&
                    isValidId(bookingId) &&
                    isValidBooking(incoming()) &&
                    incoming().userId == request.auth.uid &&
                    exists(/databases/$(database)/documents/vehicles/$(incoming().vehicleId)) &&
                    incoming().status == 'pending' &&
                    incoming().createdAt == request.time &&
                    incoming().updatedAt == request.time;
      
      allow update: if isSignedIn() &&
                    isValidId(bookingId) &&
                    isValidBooking(incoming()) &&
                    incoming().userId == existing().userId &&
                    incoming().vehicleId == existing().vehicleId &&
                    incoming().createdAt == existing().createdAt &&
                    incoming().updatedAt == request.time &&
                    (
                      (isAdmin()) ||
                      (incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']) &&
                       existing().status == 'pending' && incoming().status == 'cancelled')
                    );
      
      allow delete: if isAdmin() && isValidId(bookingId);
    }
  }
}
